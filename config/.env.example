# Database
DATABASE_URL=postgres://tradebot:tradebot_dev@localhost:15432/tradebot
# DATABASE_POOL_SIZE=10

# Redis (KV cache only)
REDIS_URL=redis://localhost:6379

# NATS (messaging)
NATS_URL=nats://localhost:4222

# Kalshi
# Demo environment (safe — mock funds)
KALSHI_API_KEY=<your-key-id>
KALSHI_PRIVATE_KEY_PATH=config/kalshi_dev.pem
KALSHI_BASE_URL=https://demo-api.kalshi.co
KALSHI_WS_URL=wss://demo-api.kalshi.co/trade-api/ws/v2
# Production (uncomment when ready for live trading):
# KALSHI_BASE_URL=https://api.elections.kalshi.com
# KALSHI_WS_URL=wss://api.elections.kalshi.com/trade-api/ws/v2

# Binance US
BINANCE_WS_URL=wss://stream.binance.us:9443/ws/btcusd@trade
BINANCE_SPOT_WS_URL=wss://stream.binance.us:9443/ws/btcusd@trade
BINANCE_US_API_KEY=<your-binance-us-api-key>
BINANCE_US_SECRET_KEY=<your-binance-us-secret-key>
ENABLE_BINANCE_SPOT=true

# Coinbase
ENABLE_COINBASE=true

# Binance Futures
ENABLE_BINANCE_FUTURES=true

# Deribit (DVOL)
ENABLE_DERIBIT=true

# Mesonet
MESONET_BASE_URL=https://mesonet.agron.iastate.edu

# Trading
PAPER_MODE=true
# Required when PAPER_MODE=false (live trading ceremony gate)
# CONFIRM_LIVE_TRADING=yes-i-understand-real-money
MAX_TRADE_SIZE_CENTS=2500
MAX_DAILY_LOSS_CENTS=10000
MAX_POSITIONS=5
MAX_EXPOSURE_CENTS=15000
KELLY_FRACTION_MULTIPLIER=0.25

# Crypto evaluation thresholds
# CRYPTO_ENTRY_MIN_MINUTES=3.0
# CRYPTO_ENTRY_MAX_MINUTES=20.0
# CRYPTO_MIN_EDGE=0.03
# CRYPTO_MAX_EDGE=0.25
# CRYPTO_MIN_KELLY=0.02
# CRYPTO_MIN_CONFIDENCE=0.40
# CRYPTO_COOLDOWN_SECS=30
# WEATHER_COOLDOWN_SECS=120

# RTI venue weighting (Rust crypto)
# RTI_STALE_THRESHOLD_SECS=5
# RTI_OUTLIER_THRESHOLD_PCT=0.5
# RTI_MIN_VENUES=2

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Alerts (optional)
DISCORD_WEBHOOK_URL=

# Kill switches (default: false = trading enabled)
# KILL_SWITCH_ALL=false
# KILL_SWITCH_CRYPTO=false
# KILL_SWITCH_WEATHER=false

# Grafana
# GRAFANA_ADMIN_PASSWORD=tradebot_grafana

# Server
HTTP_PORT=3030
